rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── users 컬렉션 ────────────────────────────────────────
    // - 인증된 유저만 읽기
    // - 본인 문서 생성 가능 (role은 반드시 'member')
    // - 본인은 role 변경 불가, 관리자만 변경 가능
    // - 삭제는 본인(탈퇴) 또는 관리자(강퇴)
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid)
        && request.resource.data.role == 'member';
      allow update: if isAdmin()
        || (isOwner(uid)
            && !request.resource.data.diff(resource.data)
                .affectedKeys().hasAny(['role']));
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── members 컬렉션 ──────────────────────────────────────
    // - 인증된 유저 읽기
    // - 본인 프로필 생성 가능 (createdBy == 본인 uid 강제)
    // - 수정은 본인 또는 관리자
    // - 삭제는 본인(탈퇴 시 자기 데이터 정리) 또는 관리자(강퇴 시 정리)
    match /members/{memberId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        || (isAuth() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin()
        || (isAuth() && resource.data.createdBy == request.auth.uid);
    }

    // ── events 컬렉션 ───────────────────────────────────────
    // - 인증된 유저 읽기
    // - 생성은 인증된 유저 가능 (createdBy == 본인 uid 강제)
    // - 수정: 관리자 / 작성자 본인 / 투표 필드(votes·quizAnswers)만 변경하는 경우
    // - 삭제: 관리자 또는 작성자 본인
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        || (isAuth() && resource.data.createdBy == request.auth.uid)
        || (isAuth()
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['votes', 'quizAnswers', 'reactions']));
      allow delete: if isAdmin()
        || (isAuth() && resource.data.createdBy == request.auth.uid);
    }

    // ── notices 컬렉션 ──────────────────────────────────────
    // - 인증된 유저 읽기, 관리자만 쓰기
    match /notices/{noticeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── gallery 컬렉션 ──────────────────────────────────────
    // - 인증된 유저만 읽기
    // - 생성·수정은 관리자만
    // - 삭제: 관리자 또는 작성자 본인 (탈퇴 시 자기 데이터 정리)
    match /gallery/{galleryId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin()
        || (isAuth() && resource.data.createdBy == request.auth.uid);

      // 댓글 서브컬렉션
      // - 인증된 유저 읽기·작성
      // - 수정·삭제는 작성자 본인 또는 관리자
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.authorUid == request.auth.uid;
        allow update: if isAuth()
          && resource.data.authorUid == request.auth.uid;
        allow delete: if isAuth()
          && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    // ── dms 컬렉션 ──────────────────────────────────────────
    // - 참여자만 읽기/쓰기 가능
    match /dms/{convId} {
      allow read, update: if isAuth()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      match /messages/{msgId} {
        allow read: if isAuth()
          && request.auth.uid in
            get(/databases/$(database)/documents/dms/$(convId)).data.participants;
        allow create: if isAuth()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in
            get(/databases/$(database)/documents/dms/$(convId)).data.participants;
      }
    }

    // ── blacklist 컬렉션 ─────────────────────────────────────
    // - 회원가입 시 이메일 체크는 비인증 상태에서도 필요하므로 read는 전체 허용
    // - 쓰기(추가·삭제)는 관리자만
    match /blacklist/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
